<Application x:Class="Hinagata.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Hinagata"
             xmlns:vm="clr-namespace:Hinagata.ViewModels"
             xmlns:views="clr-namespace:Hinagata.Views">
    <Application.Resources>
         <!--データテンプレートで View と ViewModel を紐づけ-->
        <DataTemplate DataType="{x:Type vm:ContentControlCntViewModel}">
            <views:ContentControlCntView/>
        </DataTemplate>


        <DataTemplate DataType="{x:Type vm:CntViewModel}">
            <views:CntView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:EvenOddViewModel}">
            <views:EvenOddView/>
        </DataTemplate>

    </Application.Resources>
</Application>
